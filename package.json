{
  "name": "tele-rpg",
  "version": "0.1.0",
  "description": "Telegram MMORPG - Codename: RiftChronicles",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --esm src/index.ts",
    "migrate": "ts-node --esm src/database/migrateToLatest.ts",
    "seed": "ts-node --esm src/database/seed.ts",
    "lint": "eslint . --ext .ts",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KnightNiwrem/TeleRPG-G.git"
  },
  "keywords": [
    "telegram",
    "bot",
    "rpg",
    "game",
    "mmorpg"
  ],
  "author": "KnightNiwrem",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/KnightNiwrem/TeleRPG-G/issues"
  },
  "homepage": "https://github.com/KnightNiwrem/TeleRPG-G#readme",
  "dependencies": {
    "bullmq": "^5.0.0",
    "dotenv": "^16.0.3",
    "grammy": "^1.15.3",
    "ioredis": "^5.3.2",
    "kysely": "^0.28.0",
    "pg": "^8.16.0",
    "zod": "^3.25.23"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.10.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  }
}
